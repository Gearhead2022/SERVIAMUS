generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Users {
  user_id    Int     @id @default(autoincrement())
  name       String  @db.VarChar(50)
  username   String  @unique
  password   String  @db.Text
  is_active  Boolean @default(true)
  license_no String? @db.VarChar(20)
  title      String? @db.VarChar(50)
  ptr_no     String? @db.VarChar(20)

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  roles         UserRole[]
  prescriptions Prescription[]

  processed_lab_items                       LaboratoryRequestItem[]
  hematology_results_as_medtech             HematologyResult[]          @relation("HematologyResultMedTech")
  hematology_results_as_pathologist         HematologyResult[]          @relation("HematologyResultPathologist")
  serology_results_as_medtech               SerologyResult[]            @relation("SerologyResultMedTech")
  serology_results_as_pathologist           SerologyResult[]            @relation("SerologyResultPathologist")
  parasitology_results_as_medtech           ParasitologyResult[]        @relation("ParasitologyResultMedTech")
  parasitology_results_as_pathologist       ParasitologyResult[]        @relation("ParasitologyResultPathologist")
  urinalysis_results_as_medtech             UrinalysisResult[]          @relation("UrinalysisResultMedTech")
  urinalysis_results_as_pathologist         UrinalysisResult[]          @relation("UrinalysisResultPathologist")
  clinical_chemistry_results_as_medtech     ClinicalChemistryResult[]   @relation("ClinicalChemistryResultMedTech")
  clinical_chemistry_results_as_pathologist ClinicalChemistryResult[]   @relation("ClinicalChemistryResultPathologist")
  hba1c_results_as_medtech                  HbA1cResult[]               @relation("HbA1cResultMedTech")
  hba1c_results_as_pathologist              HbA1cResult[]               @relation("HbA1cResultPathologist")
  chemistry_results_as_medtech              ChemistryResult[]           @relation("ChemistryResultMedTech")
  chemistry_results_as_pathologist          ChemistryResult[]           @relation("ChemistryResultPathologist")
  ogtt_results_as_medtech                   OgttResult[]                @relation("OgttResultMedTech")
  ogtt_results_as_pathologist               OgttResult[]                @relation("OgttResultPathologist")
  medical_certificate_request_as_doctor     MedicalCertificateRequest[] @relation("MedicalCertificateRequestDoctor")
  consultation_request_as_doctor            ConsultationRequest[]       @relation("ConsultationRequestDoctor")

  @@map("users")
}

model RoleTypes {
  role_id   Int    @id @default(autoincrement())
  role_name String @db.VarChar(50)

  role_desc String? @db.VarChar(100)

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  users UserRole[]

  @@map("roles")
}

model UserRole {
  user_id Int
  role_id Int

  user Users     @relation(fields: [user_id], references: [user_id])
  role RoleTypes @relation(fields: [role_id], references: [role_id], onDelete: Cascade)

  @@id([user_id, role_id])
  @@index([user_id])
  @@index([role_id])
  @@map("user_roles")
}

model VitallSign {
  vs_id      Int       @id @default(autoincrement())
  patient_id Int
  bp         String?   @db.VarChar(20)
  temp       String?   @db.VarChar(20)
  cr         String?   @db.VarChar(20)
  rr         String?   @db.VarChar(20)
  wt         String?   @db.VarChar(20)
  ht         String?   @db.VarChar(20)
  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  phr           ConsultationRecords[]
  cons_req      ConsultationRequest[]
  patient       Patients              @relation(fields: [patient_id], references: [patient_id])
  consultations Consultation[]

  @@map("vital_signs")
}

model Consultation {
  consultation_id Int @id @default(autoincrement())

  patient_id Int
  cons_id    Int
  vs_id      Int?
  phr_id     Int?

  consultation_date DateTime @db.Date

  chief_complaint String?
  hist_illness    String?

  examination String?
  assessment  String?
  plans       String?

  follow_up_date DateTime?

  created_at DateTime @default(now())

  patient        Patients             @relation(fields: [patient_id], references: [patient_id])
  vitals         VitallSign?          @relation(fields: [vs_id], references: [vs_id])
  consultRecords ConsultationRecords? @relation(fields: [phr_id], references: [phr_id])
  consultRequest ConsultationRequest  @relation(fields: [cons_id], references: [cons_id])

  prescriptions Prescription[]

  @@index([patient_id])
  @@map("consultation")
}

model ConsultationRecords {
  phr_id     Int @id @default(autoincrement())
  patient_id Int @unique

  pmh_allergy     Boolean @default(false)
  pmh_admission   Boolean @default(false)
  pmh_others      Boolean @default(false)
  pmh_others_text String?

  fh_htn         Boolean @default(false)
  fh_dm          Boolean @default(false)
  fh_ba          Boolean @default(false)
  fh_cancer      Boolean @default(false)
  fh_others      Boolean @default(false)
  fh_others_text String?

  ob_score String?
  ob_nvsd  Boolean @default(false)
  ob_cs    Boolean @default(false)

  menarche    String? @db.VarChar(100)
  interval    String? @db.VarChar(100)
  duration    String? @db.VarChar(100)
  amount      String? @db.VarChar(100)
  ob_symptoms String? @db.VarChar(100)

  cigarette_use Boolean @default(false)
  alcohol_use   Boolean @default(false)
  drug_use      Boolean @default(false)
  exercise      Boolean @default(false)
  hygiene_prac  Boolean @default(false)
  coffee_cons   Boolean @default(false)
  soda_cons     Boolean @default(false)

  sh_allergy   Boolean @default(false)
  sh_admission Boolean @default(false)

  travel_history String? @db.VarChar(100)
  diet           String? @db.VarChar(100)
  stress         String? @db.VarChar(100)
  occupation     String? @db.VarChar(100)

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  patient Patients       @relation(fields: [patient_id], references: [patient_id])
  consult Consultation[]

  vitallSign      VitallSign? @relation(fields: [vitallSignVs_id], references: [vs_id])
  vitallSignVs_id Int?

  @@index([patient_id])
  @@map("consultation_records")
}

enum Sex {
  male
  female
}

model Request {
  req_id     Int           @id @default(autoincrement())
  patient_id Int
  req_type   RequestType
  status     RequestStatus
  req_date   DateTime      @db.Date

  patient             Patients                  @relation(fields: [patient_id], references: [patient_id])
  laboratory          LaboratoryRequest?
  consult             ConsultationRequest?
  medical_certificate MedicalCertificateResult?
  billing             Billing?

  @@index([patient_id])
  @@map("request")
}

enum RequestType {
  CONSULTATION
  LABORATORY
  CERTIFICATE
}

enum RequestStatus {
  WAITING
  SERVING
  CANCELED
  DONE
}

model ConsultationRequest {
  cons_id   Int @id @default(autoincrement())
  req_id    Int @unique
  vs_id     Int
  physician Int

  request       Request        @relation(fields: [req_id], references: [req_id])
  vitals        VitallSign     @relation(fields: [vs_id], references: [vs_id])
  consultations Consultation[]
  doctor        Users?         @relation("ConsultationRequestDoctor", fields: [physician], references: [user_id])

  @@map("consultation_request")
}

model MedicalCertificateRequest {
  mcr_id    Int    @id @default(autoincrement())
  req_id    Int    @unique
  physician Int
  purpose   String @db.VarChar(50)

  request     Request                   @relation(fields: [req_id], references: [req_id])
  certificate MedicalCertificateResult?
  doctor      Users?                    @relation("MedicalCertificateRequestDoctor", fields: [physician], references: [user_id])

  @@map("med_cert_request")
}

model MedicalCertificateResult {
  med_cert_id    Int       @id @default(autoincrement())
  mcr_id         Int       @unique
  patient_id     Int
  purpose        String    @db.VarChar(50)
  impression     String?   @db.Text
  recommendation String?   @db.Text
  result_date    DateTime  @db.Date
  created_at     DateTime  @default(now())
  updated_at     DateTime? @updatedAt

  patient          Patients                  @relation(fields: [patient_id], references: [patient_id])
  med_cert_request MedicalCertificateRequest @relation(fields: [mcr_id], references: [mcr_id])

  @@index([patient_id])
  @@map("med_cert_results")
}

model Prescription {
  presc_id Int @id @default(autoincrement())

  consultation_id Int
  patient_id      Int
  doctor_id       Int

  gen_notes String?

  consultation Consultation @relation(fields: [consultation_id], references: [consultation_id])
  patient      Patients     @relation(fields: [patient_id], references: [patient_id])
  doctor       Users        @relation(fields: [doctor_id], references: [user_id])

  medicines PrescriptionItem[]

  created_at DateTime @default(now())

  @@map("prescriptions")
}

model PrescriptionItem {
  item_id Int @id @default(autoincrement())

  presc_id Int

  medicine_name String
  strength      String?

  form      String
  dose      String
  frequency String
  route     String
  duration  String
  quantity  String?

  instruction String?

  prescription Prescription @relation(fields: [presc_id], references: [presc_id], onDelete: Cascade)

  @@map("prescription_items")
}

model LaboratoryRequest {
  id     Int    @id @default(autoincrement())
  req_id Int    @unique
  req_by String @db.VarChar(50)

  request Request                 @relation(fields: [req_id], references: [req_id])
  items   LaboratoryRequestItem[]

  @@map("laboratory_request")
}

model LaboratoryTest {
  test_id    Int                @id @default(autoincrement())
  name       String             @db.VarChar(100)
  category   LaboratoryCategory @default(OTHER)
  schema_key String?            @db.VarChar(50)

  items LaboratoryRequestItem[]

  @@map("laboratory_tests")
}

model LaboratoryRequestItem {
  item_id Int @id @default(autoincrement())

  laboratory_request_id Int
  test_id               Int

  status         LaboratoryRequestItemStatus @default(QUEUED)
  result_payload Json?
  processed_by   Int?

  completed_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime? @updatedAt

  laboratoryRequest         LaboratoryRequest        @relation(fields: [laboratory_request_id], references: [id], onDelete: Cascade)
  test                      LaboratoryTest           @relation(fields: [test_id], references: [test_id])
  processor                 Users?                   @relation(fields: [processed_by], references: [user_id])
  hematology_result         HematologyResult?
  serology_result           SerologyResult?
  parasitology_result       ParasitologyResult?
  urinalysis_result         UrinalysisResult?
  clinical_chemistry_result ClinicalChemistryResult?
  hba1c_result              HbA1cResult?
  chemistry_result          ChemistryResult?
  ogtt_result               OgttResult?

  @@index([laboratory_request_id])
  @@index([status])
  @@index([processed_by])
  @@map("laboratory_request_items")
}

enum LaboratoryCategory {
  Clinical_Chemistry
  Clinical_Microscopy
  Serology
  Hematology
  OTHER
}

enum LaboratoryRequestItemStatus {
  QUEUED
  PROCESSING
  DONE
  CANCELLED
}

model Patients {
  patient_id     Int      @id @default(autoincrement())
  patient_code   String?  @unique
  name           String   @db.VarChar(50)
  address        String   @db.Text
  contact_number String   @db.VarChar(50)
  birth_date     DateTime @db.Date
  religion       String?  @db.VarChar(50)

  sex Sex
  age Int?

  created_at DateTime  @default(now())
  updated_at DateTime? @updatedAt

  phr                       ConsultationRecords[]
  request                   Request[]
  vitals                    VitallSign[]
  prescriptions             Prescription[]
  consultations             Consultation[]
  hematologyResults         HematologyResult[]
  serologyResults           SerologyResult[]
  parasitologyResults       ParasitologyResult[]
  urinalysisResults         UrinalysisResult[]
  clinicalChemistryResults  ClinicalChemistryResult[]
  hbA1CResults              HbA1cResult[]
  chemistryResults          ChemistryResult[]
  ogttResults               OgttResult[]
  medicalCertificateResults MedicalCertificateResult[]

  hematology_results          HematologyResult[]
  serology_results            SerologyResult[]
  parasitology_results        ParasitologyResult[]
  urinalysis_results          UrinalysisResult[]
  clinical_chemistry_results  ClinicalChemistryResult[]
  hba1c_results               HbA1cResult[]
  chemistry_results           ChemistryResult[]
  ogtt_results                OgttResult[]
  medical_certificate_results MedicalCertificateResult[]

  @@map("patients")
}

// Service Class
model ServiceClass {
  class_id    Int     @id @default(autoincrement())
  class_code  String  @unique @db.VarChar(20)
  description String  @db.VarChar(200)
  is_active   Boolean @default(true)

  services Services[]

  @@map("service_class")
}

// Services
model Services {
  service_id   Int      @id @default(autoincrement())
  service_code String   @unique @db.VarChar(20)
  price        Decimal  @db.Decimal(12, 2)
  date         DateTime @db.Date
  is_active    Boolean  @default(true)
  class_id     Int

  serviceClass ServiceClass     @relation(fields: [class_id], references: [class_id])
  billingItems BillingService[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("services")
}

// Billing
model Billing {
  billing_id   Int        @id @default(autoincrement())
  billing_code String     @unique @db.VarChar(20)
  req_id       Int        @unique
  total_price  Decimal    @db.Decimal(12, 2)
  date         DateTime   @db.Date
  discount     Decimal    @db.Decimal(12, 2)
  status       BillStatus

  services BillingService[]
  request  Request          @relation(fields: [req_id], references: [req_id])
  payments Payment[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("biling")
}

enum BillStatus {
  PENDING
  DONE
}

// Billing Services (Pivot Table)
model BillingService {
  service_list_id Int @id @default(autoincrement())

  billing_id Int
  service_id Int

  billing Billing  @relation(fields: [billing_id], references: [billing_id])
  service Services @relation(fields: [service_id], references: [service_id])

  price Decimal? @db.Decimal(12, 2)

  @@map("billing_services")
}

model Payment {
  payment_id Int @id @default(autoincrement())

  billing_id Int
  billing    Billing @relation(fields: [billing_id], references: [billing_id])

  amount       Decimal       @db.Decimal(12, 2)
  method       PaymentMethod
  payment_date DateTime      @default(now())

  reference_no String? @db.VarChar(50) // for GCash / bank / etc.

  created_at DateTime @default(now())
}

enum PaymentMethod {
  CASH
  GCASH
  CARD
  BANK_TRANSFER
}

model HematologyResult {
  ht_id              Int       @id @default(autoincrement())
  patient_id         Int
  lab_id             Int       @unique
  hemoglobin         String?   @db.VarChar(50)
  rbc_count          String?   @db.VarChar(50)
  wbc_count          String?   @db.VarChar(50)
  platelet_count     String?   @db.VarChar(50)
  others_mcv         String?   @db.VarChar(50)
  mchc               String?   @db.VarChar(50)
  reticulocyte_count String?   @db.VarChar(50)
  nss_1              String?   @db.VarChar(50)
  nss_2              String?   @db.VarChar(50)
  nss_3              String?   @db.VarChar(50)
  lymphocytes        String?   @db.VarChar(50)
  monocytes          String?   @db.VarChar(50)
  eosinophils        String?   @db.VarChar(50)
  basophils          String?   @db.VarChar(50)
  others1            String?   @db.Text
  clotting_time      String?   @db.VarChar(50)
  bleeding_time      String?   @db.VarChar(50)
  blood_type         String?   @db.VarChar(20)
  abo_type           String?   @db.VarChar(20)
  rh_type            String?   @db.VarChar(20)
  others2            String?   @db.Text
  med_tech_user_id   Int?
  pth_user_id        Int?
  result_date        DateTime  @default(now()) @db.Date
  created_at         DateTime  @default(now())
  updated_at         DateTime? @updatedAt

  patient     Patients              @relation(fields: [patient_id], references: [patient_id])
  lab         LaboratoryRequestItem @relation(fields: [lab_id], references: [item_id], onDelete: Cascade)
  med_tech    Users?                @relation("HematologyResultMedTech", fields: [med_tech_user_id], references: [user_id])
  pathologist Users?                @relation("HematologyResultPathologist", fields: [pth_user_id], references: [user_id])

  @@index([patient_id])
  @@index([med_tech_user_id])
  @@index([pth_user_id])
  @@map("hematology_results")
}

model SerologyResult {
  st_id            Int       @id @default(autoincrement())
  patient_id       Int
  lab_id           Int       @unique
  test_name        String?   @db.VarChar(100)
  method           String?   @db.VarChar(100)
  specimen         String?   @db.VarChar(100)
  result           String?   @db.Text
  day_of_fever     String?   @db.VarChar(50)
  med_tech_user_id Int?
  pth_user_id      Int?
  result_date      DateTime  @default(now()) @db.Date
  created_at       DateTime  @default(now())
  updated_at       DateTime? @updatedAt

  patient     Patients              @relation(fields: [patient_id], references: [patient_id])
  lab         LaboratoryRequestItem @relation(fields: [lab_id], references: [item_id], onDelete: Cascade)
  med_tech    Users?                @relation("SerologyResultMedTech", fields: [med_tech_user_id], references: [user_id])
  pathologist Users?                @relation("SerologyResultPathologist", fields: [pth_user_id], references: [user_id])

  @@index([patient_id])
  @@index([med_tech_user_id])
  @@index([pth_user_id])
  @@map("serology_results")
}

model ParasitologyResult {
  pr_id                   Int       @id @default(autoincrement())
  patient_id              Int
  lab_id                  Int       @unique
  time_collected          String?   @db.VarChar(50)
  time_received           String?   @db.VarChar(50)
  color                   String?   @db.VarChar(50)
  consistency             String?   @db.VarChar(50)
  pus_cells               String?   @db.VarChar(50)
  rbc                     String?   @db.VarChar(50)
  bacteria                String?   @db.VarChar(50)
  hookworm                String?   @db.VarChar(50)
  ascaris                 String?   @db.VarChar(50)
  trichuris               String?   @db.VarChar(50)
  strongloides            String?   @db.VarChar(50)
  histolytica_cyst        String?   @db.VarChar(50)
  histolytica_trophozoite String?   @db.VarChar(50)
  coli_cyst               String?   @db.VarChar(50)
  coli_trophozoite        String?   @db.VarChar(50)
  others                  String?   @db.Text
  med_tech_user_id        Int?
  pth_user_id             Int?
  result_date             DateTime  @default(now()) @db.Date
  created_at              DateTime  @default(now())
  updated_at              DateTime? @updatedAt

  patient     Patients              @relation(fields: [patient_id], references: [patient_id])
  lab         LaboratoryRequestItem @relation(fields: [lab_id], references: [item_id], onDelete: Cascade)
  med_tech    Users?                @relation("ParasitologyResultMedTech", fields: [med_tech_user_id], references: [user_id])
  pathologist Users?                @relation("ParasitologyResultPathologist", fields: [pth_user_id], references: [user_id])

  @@index([patient_id])
  @@index([med_tech_user_id])
  @@index([pth_user_id])
  @@map("parasitology_results")
}

model UrinalysisResult {
  ur_id            Int       @id @default(autoincrement())
  patient_id       Int
  lab_id           Int       @unique
  color            String?   @db.VarChar(50)
  transparency     String?   @db.VarChar(50)
  ph_result        String?   @db.VarChar(50)
  spec_grav_result String?   @db.VarChar(50)
  protein          String?   @db.VarChar(50)
  nitrite          String?   @db.VarChar(50)
  glucose          String?   @db.VarChar(50)
  ketones          String?   @db.VarChar(50)
  leukocytes       String?   @db.VarChar(50)
  blood            String?   @db.VarChar(50)
  pus_cells        String?   @db.VarChar(50)
  rbc              String?   @db.VarChar(50)
  bacteria         String?   @db.VarChar(50)
  squamous_cell    String?   @db.VarChar(50)
  round_cell       String?   @db.VarChar(50)
  mucous           String?   @db.VarChar(50)
  crystals         String?   @db.VarChar(50)
  casts            String?   @db.VarChar(50)
  others           String?   @db.Text
  med_tech_user_id Int?
  pth_user_id      Int?
  result_date      DateTime  @default(now()) @db.Date
  created_at       DateTime  @default(now())
  updated_at       DateTime? @updatedAt

  patient     Patients              @relation(fields: [patient_id], references: [patient_id])
  lab         LaboratoryRequestItem @relation(fields: [lab_id], references: [item_id], onDelete: Cascade)
  med_tech    Users?                @relation("UrinalysisResultMedTech", fields: [med_tech_user_id], references: [user_id])
  pathologist Users?                @relation("UrinalysisResultPathologist", fields: [pth_user_id], references: [user_id])

  @@index([patient_id])
  @@index([med_tech_user_id])
  @@index([pth_user_id])
  @@map("urinalysis_results")
}

model ClinicalChemistryResult {
  cc_id                Int       @id @default(autoincrement())
  patient_id           Int
  lab_id               Int       @unique
  fbs                  String?   @db.VarChar(50)
  rbs                  String?   @db.VarChar(50)
  bun                  String?   @db.VarChar(50)
  creatinine           String?   @db.VarChar(50)
  uric_acid            String?   @db.VarChar(50)
  cholesterol          String?   @db.VarChar(50)
  hdl_cholesterol      String?   @db.VarChar(50)
  ldl_cholesterol      String?   @db.VarChar(50)
  triglycerides        String?   @db.VarChar(50)
  sgpt                 String?   @db.VarChar(50)
  fbs_conv             String?   @db.VarChar(50)
  rbs_conv             String?   @db.VarChar(50)
  bun_conv             String?   @db.VarChar(50)
  creatinine_conv      String?   @db.VarChar(50)
  uric_acid_conv       String?   @db.VarChar(50)
  cholesterol_conv     String?   @db.VarChar(50)
  hdl_cholesterol_conv String?   @db.VarChar(50)
  ldl_cholesterol_conv String?   @db.VarChar(50)
  triglycerides_conv   String?   @db.VarChar(50)
  last_meal            String?   @db.VarChar(100)
  time_taken           String?   @db.VarChar(100)
  med_tech_user_id     Int?
  pth_user_id          Int?
  result_date          DateTime  @default(now()) @db.Date
  created_at           DateTime  @default(now())
  updated_at           DateTime? @updatedAt

  patient     Patients              @relation(fields: [patient_id], references: [patient_id])
  lab         LaboratoryRequestItem @relation(fields: [lab_id], references: [item_id], onDelete: Cascade)
  med_tech    Users?                @relation("ClinicalChemistryResultMedTech", fields: [med_tech_user_id], references: [user_id])
  pathologist Users?                @relation("ClinicalChemistryResultPathologist", fields: [pth_user_id], references: [user_id])

  @@index([patient_id])
  @@index([med_tech_user_id])
  @@index([pth_user_id])
  @@map("clinical_chemistry_results")
}

model HbA1cResult {
  hba_id                Int       @id @default(autoincrement())
  patient_id            Int
  lab_id                Int       @unique
  test_method           String?   @db.VarChar(100)
  lot_no                String?   @db.VarChar(100)
  exp_date              DateTime? @db.Date
  specimen              String?   @db.VarChar(100)
  result                String?   @db.VarChar(50)
  result_interpretation String?   @db.Text
  med_tech_user_id      Int?
  pth_user_id           Int?
  result_date           DateTime  @default(now()) @db.Date
  created_at            DateTime  @default(now())
  updated_at            DateTime? @updatedAt

  patient     Patients              @relation(fields: [patient_id], references: [patient_id])
  lab         LaboratoryRequestItem @relation(fields: [lab_id], references: [item_id], onDelete: Cascade)
  med_tech    Users?                @relation("HbA1cResultMedTech", fields: [med_tech_user_id], references: [user_id])
  pathologist Users?                @relation("HbA1cResultPathologist", fields: [pth_user_id], references: [user_id])

  @@index([patient_id])
  @@index([med_tech_user_id])
  @@index([pth_user_id])
  @@map("hba1c_results")
}

model ChemistryResult {
